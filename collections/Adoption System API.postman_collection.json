    {
      "name": "TrialCohabitation",
      "item": [
        {
          "name": "New Request",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.test(\"Validar que el proceso de adopción está aprobado\", function () {\r",
                  "    if (pm.response.code === 400) {\r",
                  "        var jsonData = pm.response.json();\r",
                  "        pm.expect(jsonData.message).to.contain(\"AdoptionProcess must be approved\");\r",
                  "    } else {\r",
                  "        pm.response.to.have.status(201);\r",
                  "    }\r",
                  "});"
